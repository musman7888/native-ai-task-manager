# =============================================================================
# .dockerignore - Files excluded from Docker build context
# =============================================================================
# Purpose: Reduce build context, speed up builds, improve security
# These files are NOT sent to the Docker daemon during build
# =============================================================================

# -----------------------------------------------------------------------------
# Virtual Environments (container creates its own)
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.uv/

# -----------------------------------------------------------------------------
# Python Artifacts (regenerated in container)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# Secrets & Environment (NEVER include in images)
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.crt
secrets/
credentials/

# -----------------------------------------------------------------------------
# Git (not needed, saves space)
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Docker Files (recursive inclusion prevention)
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.dockerignore

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Testing (not needed in production images)
# -----------------------------------------------------------------------------
tests/
test_*.py
*_test.py
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Documentation (not needed at runtime)
# -----------------------------------------------------------------------------
# Note: README.md is NOT excluded - needed by hatchling build backend
docs/
CHANGELOG*
CONTRIBUTING*

# -----------------------------------------------------------------------------
# CI/CD Configurations
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
Jenkinsfile
