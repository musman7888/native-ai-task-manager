# Tasks Agent Environment Variables
# Copy this file to .env and fill in your API keys

# Required: OpenAI API key (for SDK tracing/observability)
OPENAI_API_KEY=sk-...

# Required: Google Gemini API key (for LLM inference)
GEMINI_API_KEY=...

# Optional: MCP server URL (default: http://localhost:8000/mcp)
TASKS_MCP_URL=http://localhost:8000/mcp

# Optional: Model ID (default: gemini/gemini-3.1-flash-lite-preview)
AGENT_MODEL=gemini/gemini-3.1-flash-lite-preview

# Optional: Log level (default: INFO)
LOG_LEVEL=INFO
